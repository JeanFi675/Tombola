# Ces variables sont injectées au BUILD via GitHub Secrets (préfixe NEXT_PUBLIC_)
# Pour le dev local, copier ce fichier en .env.local

NEXT_PUBLIC_NOCODB_URL=https://your-nocodb-instance.com
NEXT_PUBLIC_NOCODB_TOKEN=your-nocodb-api-token
NEXT_PUBLIC_NOCODB_TABLE_ID=vw88ee9tudg8uev0

# Hash SHA-256 du mot de passe (généré automatiquement par le workflow GitHub Actions)
# En local : echo -n "votre-mot-de-passe" | sha256sum
NEXT_PUBLIC_SITE_PASSWORD_HASH=your-sha256-hash-here

# Préfixe URL GitHub Pages (ex: /Tombola). Laisser vide si domaine custom.
NEXT_PUBLIC_BASE_PATH=/Tombola
